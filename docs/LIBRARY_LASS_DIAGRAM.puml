@startuml
skinparam classAttributeIconSize 0
hide circle

'======================
' NGUOI DUNG
'======================

class ThuThu {
  maThuThu: String
  hoTen: String
  email: String
  soDienThoai: String
  tenDangNhap: String
  matKhau: String
}

class DocGia {
  maDocGia: String
  hoTen: String
  email: String
  soDienThoai: String
  tenDangNhap: String
  matKhau: String
  diaChi: String
  ngayDangKy: Date
}

class QuanTriVien {
  maQuanTri: String
  hoTen: String
  email: String
  soDienThoai: String
  tenDangNhap: String
  matKhau: String
}

'======================
' QUAN LY SACH
'======================

class DanhMucSach {
  maDanhMuc: String
  tenDanhMuc: String
  moTa: String
}

class DauSach {
  maDauSach: String
  tenSach: String
  tacGia: String
  nhaXuatBan: String
  namXuatBan: int
}

class QuyenSach {
  maQuyenSach: String
  ngayNhap: Date
  tinhTrang: String
  trangThai: String
  viTri: String
}

'======================
' MUON / TRA
'======================

class QuanLyMuonTra {
  tab1: DuyetMuonSach
  tab2: XuLiTraSach
}

class PhieuYeuCauMuon {
  maYeuCau: String
  ngayTaoYeuCau: Date
  ngayMuonDuKien: Date
  soNgayMuon: int
  trangThai: String
}

class PhieuMuon {
  maPhieuMuon: String
  maYeuCau: String
  ngayMuon: Date
  hanTra: Date
  ngayTraThuc: Date
  trangThai: String
  tienPhat: double
  daThuPhat: boolean
}

'======================
' HE THONG
'======================

class ThongBao {
  maThongBao: String
  maDocGia: String
  noiDung: String
  nguoiGui: String
  ngayGui: Date
  trangThai: String
  daDoc: boolean
}

class NhatKyHeThong {
  maNhatKy: String
  hanhDong: String
  thoiGian: Date
}

class CauHinhHeThong {
  soNgayMuonToiDa: int
  soSachMuonToiDa: int
  phiPhatMoiNgay: double
}

'======================
' QUAN HE
'======================

DanhMucSach "1" -- "n" DauSach
DauSach "1" -- "n" QuyenSach

DocGia "1" -- "n" PhieuYeuCauMuon
DocGia "1" -- "n" PhieuMuon

PhieuYeuCauMuon "1" --> "0..1" PhieuMuon
QuyenSach "1" -- "n" PhieuMuon

DocGia "1" -- "n" ThongBao

QuanTriVien "1" -- "n" NhatKyHeThong
QuanTriVien "1" -- "1" CauHinhHeThong

ThuThu "1" -- "n" PhieuMuon
ThuThu "1" -- "n" PhieuYeuCauMuon
ThuThu "1" -- "n" ThongBao
ThuThu "1" -- "1" QuanLyMuonTra

@enduml
